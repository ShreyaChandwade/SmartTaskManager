<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginTop="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Smart Task Manager"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Version 1.0.0"
        android:textSize="14sp"
        android:textColor="#888"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Easily manage your daily tasks, schedule reminders, add voice notes, and more. Use this app to boost your productivity to the next level!"
        android:textSize="16sp"
        android:textAlignment="center"
        android:layout_marginTop="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Developed by Shreya Chandwade"
        android:textSize="16sp"
        android:textStyle="italic"
        android:textAlignment="center"
        android:textColor="#555"
        android:layout_marginTop="32dp" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
        
    <Button
        android:id="@+id/shareAppBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Share App"
        android:layout_marginBottom="32dp" />

</LinearLayout>
